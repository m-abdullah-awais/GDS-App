# ─── Firebase (Android google-services.json generation) ───
FIREBASE_PROJECT_NUMBER=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_ANDROID_MOBILESDK_APP_ID=
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_PACKAGE_NAME=com.gdsmobileapplication

# ─── Firebase runtime flags ───
FUNCTIONS_REGION=europe-west2
USE_EMULATOR=false
EMULATOR_HOST=localhost

# ─── Stripe ───
STRIPE_PUBLISHABLE_KEY=

# ─── Deep Linking ───
DEEP_LINK_SCHEME=gds
